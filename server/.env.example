# .env.example — Ortam Değişkenleri Şablonu
# Bu dosyayı kopyalayarak .env adıyla kaydedin:
#   cp .env.example .env
# Ardından değerleri kendi ortamınıza göre doldurun.

# MongoDB bağlantı adresi
# Yerel kullanım:       mongodb://localhost:27017/kampusYemek
# MongoDB Atlas örneği: mongodb+srv://<kullanici>:<sifre>@cluster0.xxxxx.mongodb.net/kampusYemek
MONGO_URI=mongodb://localhost:27017/kampusYemek

# Sunucunun dinleyeceği port
PORT=5000
